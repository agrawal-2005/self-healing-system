# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.venv-test/
venv/
*.egg-info/

# Environment / secrets — never commit these
.env
.env.*
# But do commit the example template (no real secrets inside)
!.env.example

# Docker
*.log

# Lambda build artifacts — not needed in source control
*.zip
lambda-package/
aws/lambda/services_config.json

# Recovery agent runtime data — keep the directory, ignore the data files
recovery-agent/data/*.jsonl
# Crash report content is runtime-generated; keep the directory + README only
recovery-agent/data/crash_reports/incidents/*.txt
recovery-agent/data/crash_reports/tests/*.txt

# macOS
.DS_Store

# Claude Code internal state
.claude/
