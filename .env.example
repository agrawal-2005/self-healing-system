# =============================================================================
# .env.example — project-level environment variable reference
#
# DO NOT put real credentials in this file. It is committed to git.
# Copy to the appropriate service .env file and fill in real values.
#
# monitor/.env  — used directly by the monitor process
# docker-compose also loads monitor/.env for api-service and recovery-agent
#   (for AWS credentials only; service-specific vars are in docker-compose.yml)
# =============================================================================

# ── AWS Credentials ──────────────────────────────────────────────────────────
# IAM user: self-healing-monitor (or equivalent)
# Required permissions: see aws/cloudwatch/iam_cloudwatch_policy.json
#   + events:PutEvents (EventBridge)
#   + lambda:InvokeFunction (Lambda)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_DEFAULT_REGION=us-east-1

# ── Service URLs (monitor process, running on localhost) ──────────────────────
API_SERVICE_URL=http://localhost:8000
CORE_SERVICE_URL=http://localhost:8001
FALLBACK_SERVICE_URL=http://localhost:8002

# ── Monitor behaviour ─────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=5
REQUEST_TIMEOUT_SECONDS=3.0
LATENCY_WARN_MS=500.0
LATENCY_SLOW_MS=1000.0
EVENT_COOLDOWN_SECONDS=60

# ── EventBridge ───────────────────────────────────────────────────────────────
EVENTBRIDGE_ENABLED=true
EVENTBRIDGE_EVENT_BUS=default
EVENTBRIDGE_SOURCE=selfhealing.local
EVENTBRIDGE_DETAIL_TYPE=ServiceFailureDetected
DRY_RUN=false

# ── CloudWatch (Phase 4) ──────────────────────────────────────────────────────
# Set to true to publish custom metrics to CloudWatch.
# When false, all metric calls are no-ops (app never crashes either way).
CLOUDWATCH_ENABLED=true
CLOUDWATCH_NAMESPACE=SelfHealingSystem
